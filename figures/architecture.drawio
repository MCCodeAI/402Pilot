<mxfile host="app.diagrams.net" modified="2026-05-06T00:00:00.000Z" agent="claude" version="24.0.0">
  <diagram name="402Pilot Architecture" id="arch">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="800" math="1" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- ================== AGENT (top) ================== -->
        <mxCell id="agent" value="&lt;b&gt;AGENT&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px;color:#555&quot;&gt;task workload&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;strokeWidth=2;align=center;verticalAlign=middle" vertex="1" parent="1">
          <mxGeometry x="440" y="40" width="320" height="60" as="geometry"/>
        </mxCell>

        <!-- ================== 402Pilot OUTER BOX ================== -->
        <mxCell id="pilot_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;dashed=0;strokeWidth=2;verticalAlign=top" vertex="1" parent="1">
          <mxGeometry x="80" y="160" width="1040" height="280" as="geometry"/>
        </mxCell>
        <mxCell id="pilot_label" value="&lt;b&gt;402Pilot Decision Layer&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;fontSize=15;fontColor=#1f3a68" vertex="1" parent="1">
          <mxGeometry x="100" y="170" width="400" height="26" as="geometry"/>
        </mxCell>

        <!-- Inside 402Pilot: Context Encoder -->
        <mxCell id="encoder" value="&lt;b&gt;Context Encoder&lt;/b&gt;&lt;br&gt;&lt;br&gt;task → $$\mathbf{x}_t$$" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#1f3a68;fontSize=12;strokeWidth=1.5" vertex="1" parent="1">
          <mxGeometry x="140" y="240" width="200" height="100" as="geometry"/>
        </mxCell>

        <!-- Inside 402Pilot: Policy (center, larger) -->
        <mxCell id="policy" value="&lt;b&gt;Policy&lt;/b&gt;&lt;br&gt;&lt;br&gt;$$\texttt{select}(\mathbf{x}_t, \mathcal{A}_t, \lambda_t) \to a_t$$&lt;br&gt;$$\texttt{update}(\mathbf{x}_t, a_t, u_t, c_t)$$&lt;br&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px;color:#444&quot;&gt;Q-posterior + C-posterior&lt;br&gt;per (arm, task-type)&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#1f3a68;fontSize=12;strokeWidth=2" vertex="1" parent="1">
          <mxGeometry x="440" y="220" width="320" height="180" as="geometry"/>
        </mxCell>

        <!-- Inside 402Pilot: Wallet -->
        <mxCell id="wallet" value="&lt;b&gt;Wallet&lt;/b&gt;&lt;br&gt;&lt;br&gt;remaining $$B_t$$&lt;br&gt;exposes $$\lambda_t, \mathcal{A}_t$$" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#1f3a68;fontSize=12;strokeWidth=1.5" vertex="1" parent="1">
          <mxGeometry x="860" y="240" width="200" height="120" as="geometry"/>
        </mxCell>

        <!-- ================== SETTLEMENT BOUNDARY ================== -->
        <mxCell id="boundary_line" style="endArrow=none;html=1;dashed=1;dashPattern=10 6;strokeColor=#888888;strokeWidth=1.5" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="60" y="465" as="sourcePoint"/>
            <mxPoint x="1140" y="465" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="boundary_label" value="settlement boundary" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=2;fontColor=#888888;fillColor=#ffffff" vertex="1" parent="1">
          <mxGeometry x="510" y="453" width="180" height="24" as="geometry"/>
        </mxCell>

        <!-- ================== EXTERNAL (x402 + Provider + Evaluator) ================== -->
        <mxCell id="ext_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;dashed=1;strokeWidth=1.5;verticalAlign=top" vertex="1" parent="1">
          <mxGeometry x="80" y="500" width="1040" height="240" as="geometry"/>
        </mxCell>
        <mxCell id="ext_label" value="&lt;b&gt;Outside the layer&lt;/b&gt;: x402 / AP2 / A402 / A2A-x402 protocol stack" style="text;html=1;align=left;verticalAlign=middle;fontSize=12;fontStyle=2;fontColor=#666666" vertex="1" parent="1">
          <mxGeometry x="100" y="510" width="600" height="24" as="geometry"/>
        </mxCell>

        <!-- x402 stack -->
        <mxCell id="x402" value="&lt;b&gt;x402 stack&lt;/b&gt;&lt;br&gt;&lt;br&gt;quote → settle → call" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#666666;fontSize=12;strokeWidth=1.5" vertex="1" parent="1">
          <mxGeometry x="140" y="560" width="220" height="120" as="geometry"/>
        </mxCell>

        <!-- Provider -->
        <mxCell id="provider" value="&lt;b&gt;Provider&lt;/b&gt;&lt;br&gt;&lt;br&gt;LLM call" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#666666;fontSize=12;strokeWidth=1.5" vertex="1" parent="1">
          <mxGeometry x="490" y="580" width="220" height="80" as="geometry"/>
        </mxCell>

        <!-- Evaluator -->
        <mxCell id="evaluator" value="&lt;b&gt;Evaluator&lt;/b&gt;&lt;br&gt;&lt;br&gt;score → $$(q_t, c_t, f_t)$$" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#666666;fontSize=12;strokeWidth=1.5" vertex="1" parent="1">
          <mxGeometry x="840" y="580" width="220" height="80" as="geometry"/>
        </mxCell>

        <!-- ================== ARROWS (numbered) ================== -->

        <!-- ① Agent → Context Encoder -->
        <mxCell id="arr1" value="&lt;b&gt;① task&lt;/b&gt;" style="endArrow=classic;html=1;exitX=0.4;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeWidth=2;fontSize=12;fontStyle=1" edge="1" parent="1" source="agent" target="encoder">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ② Context Encoder → Policy -->
        <mxCell id="arr2" value="&lt;b&gt;② $$\mathbf{x}_t$$&lt;/b&gt;" style="endArrow=classic;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.4;strokeWidth=2;fontSize=12;fontStyle=1" edge="1" parent="1" source="encoder" target="policy">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ③ Wallet → Policy -->
        <mxCell id="arr3" value="&lt;b&gt;③ $$\lambda_t, \mathcal{A}_t$$&lt;/b&gt;" style="endArrow=classic;html=1;exitX=0;exitY=0.5;entryX=1;entryY=0.4;strokeWidth=2;fontSize=12;fontStyle=1" edge="1" parent="1" source="wallet" target="policy">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ④ Policy → x402 (across boundary) -->
        <mxCell id="arr4" value="&lt;b&gt;④ $$a_t$$&lt;/b&gt;" style="endArrow=classic;html=1;exitX=0.25;exitY=1;entryX=0.5;entryY=0;strokeWidth=2;fontSize=12;fontStyle=1" edge="1" parent="1" source="policy" target="x402">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ⑤ x402 → Provider (gray dashed, outside) -->
        <mxCell id="arr5" value="⑤ pay + call" style="endArrow=classic;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;dashed=1;strokeColor=#888888;strokeWidth=1.5;fontSize=10;fontColor=#666666" edge="1" parent="1" source="x402" target="provider">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ⑥ Provider → Evaluator -->
        <mxCell id="arr6" value="⑥ response" style="endArrow=classic;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;dashed=1;strokeColor=#888888;strokeWidth=1.5;fontSize=10;fontColor=#666666" edge="1" parent="1" source="provider" target="evaluator">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ⑦ Evaluator → Policy (utility + cost feedback, RED to highlight) -->
        <mxCell id="arr7" value="&lt;b&gt;⑦ $$u_t = q_t - \nu f_t,\ c_t$$&lt;/b&gt;" style="endArrow=classic;html=1;exitX=0.5;exitY=0;entryX=0.75;entryY=1;strokeColor=#cc0000;strokeWidth=2.5;fontSize=12;fontStyle=1;fontColor=#cc0000" edge="1" parent="1" source="evaluator" target="policy">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Annotation for arrow 7 -->
        <mxCell id="arr7_note" value="&lt;span style=&quot;font-size:10px;color:#cc0000;font-style:italic&quot;&gt;utility, NOT $$r_t$$&lt;/span&gt;" style="text;html=1;align=center;verticalAlign=middle;fontSize=10;fontColor=#cc0000;fontStyle=2" vertex="1" parent="1">
          <mxGeometry x="780" y="490" width="180" height="20" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
