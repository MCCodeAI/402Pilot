# Environment file template for the x402 integration-witness stack.
#
# Copy this file to `.env` in the same directory and fill in the values
# marked with `< ... >`. The docker-compose file in this directory reads
# `.env` automatically.
#
# Everything here is for LOCAL-ONLY witness runs against an Anvil fork.
# Never put a real-funds private key in this file.

# ---------------------------------------------------------------------------
# Mainnet fork
# ---------------------------------------------------------------------------

# RPC URL that Anvil forks from. Use an Ethereum mainnet RPC
# (Alchemy, Infura, public node, etc.). Anvil only reads at startup; no
# transactions are sent back to the upstream RPC.
MAINNET_FORK_RPC_URL=<your mainnet RPC URL>

# Block at which the fork is pinned. Hard-coding ensures the USDC balance
# slots and contract bytecode are deterministic across reviewer machines.
MAINNET_FORK_BLOCK=19500000

# ---------------------------------------------------------------------------
# Wallets (all keys are Anvil test accounts; safe to commit because every
# Anvil node generates the same set)
# ---------------------------------------------------------------------------

# Buyer / signer. Used by X402PaymentExecutor to sign PAYMENT-SIGNATURE
# payloads. Anvil test account 0.
X402_WALLET_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Seller / pay-to. Receives USDC for each x402 payment. Anvil test account 1.
PAY_TO_ADDRESS=0x70997970C51812dc3A010C7d01b50e0d17dc79C8

# Facilitator signer. Pays gas for settlement transactions on the local
# Anvil. Anvil test account 9, kept separate from the buyer and seller
# so log inspection is unambiguous about who initiated which tx.
FACILITATOR_PRIVATE_KEY=0x2a871d0798f97d79848a013d4936a73bf4cc922c825d33c1cf7073dff6d409c6
