# macOS
.DS_Store
.AppleDouble
.LSOverride

# Temporary / lock files
.~*
*.lock
*.bak

# Word temp files
~$*.docx
~$*.xlsx
~$*.pptx

# Python
__pycache__/
*.py[cod]
.env
.venv/
*.egg-info/

# Jupyter
.ipynb_checkpoints/

# Node
node_modules/

# Misc
*.log

# Local macOS double-click launchers.
/*.command

# 402Pilot bulk artifacts (gitignored, regenerable).
# data/tasks/ and data/pregen/ are committed as reproducibility artifacts:
# tasks define the benchmark subset, and pregen contains frozen replay records.
data/calibration/
/results/

# Build / tooling caches
build/
dist/
.mypy_cache/
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/

# Slide decks, Word documents, and local PDF exports — kept local, not in git
*.pptx
*.docx
docs/*.pdf

# Local-only experiment outputs
outputs/
logs/.ablation_metrics_cache.json

# Local working materials not published to GitHub.
logs/
paper/
viz/
viz-explainer/
scripts/export_viz_data.py

# LaTeX build artifacts
paper/*.aux
paper/*.bbl
paper/*.blg
paper/*.out
paper/*.log
paper/*.pdf
paper/*.synctex.gz
paper/*.fls
paper/*.fdb_latexmk

# Local Codex skills: project-scoped, not published to GitHub.
skills/
# Legacy location, kept ignored so skills are not accidentally reintroduced
# under paper/.
paper/skills/
