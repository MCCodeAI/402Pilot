# macOS
.DS_Store
.AppleDouble
.LSOverride

# Temporary / lock files
.~*
*.lock

# Word temp files
~$*.docx
~$*.xlsx
~$*.pptx

# Python
__pycache__/
*.py[cod]
.env
.venv/
*.egg-info/

# Jupyter
.ipynb_checkpoints/

# Node
node_modules/

# Misc
*.log

# 402Pilot bulk artifacts (gitignored, regenerable).
# data/tasks/ is committed: those JSONL files are small and define the
# experimental subset; without them, reviewers cannot reproduce the run.
data/pregen/
data/calibration/
results/

# Build / tooling caches
build/
dist/
.mypy_cache/
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/

# Slide decks and Word documents — kept local, not in git
*.pptx
*.docx

# Local-only experiment outputs
outputs/

# LaTeX build artifacts
paper/*.aux
paper/*.bbl
paper/*.blg
paper/*.out
paper/*.log
paper/*.pdf
paper/*.synctex.gz
paper/*.fls
paper/*.fdb_latexmk
