# 402Pilot environment template.
# Copy to `.env` and fill in real values. `.env` is gitignored.

# ---------------------------------------------------------------------------
# LLM provider keys — used only during Phase 1 (pregen) by pilot402/pregen/.
# Not required for Phases 2-4 (experiments replay from cached PregenRecords).
# ---------------------------------------------------------------------------
# Drives P-mid / P-premium / P-adv / P-flaky (all GPT-5.4 family).
OPENAI_API_KEY=
# Drives P-cheap (qwen3.5-flash via DashScope).
QWEN_API_KEY=

# ---------------------------------------------------------------------------
# Local Anvil DEVnet — used from Phase 2 onward.
# All experiments run on a local Anvil fork of Base; no public testnet.
# ---------------------------------------------------------------------------
ANVIL_RPC_URL=http://127.0.0.1:8545
ANVIL_CHAIN_ID=31337

# ---------------------------------------------------------------------------
# x402 wallet — Anvil-funded test account, NEVER used outside the local fork.
# ---------------------------------------------------------------------------
X402_WALLET_PRIVATE_KEY=
X402_FACILITATOR_URL=http://127.0.0.1:4021

# ---------------------------------------------------------------------------
# LLM-as-judge backend — used by pilot402/eval/judge_backend.py during pregen.
# Identity is logged per call as provenance (system_design §2.5).
#
# JUDGE_API_KEY holds the credential for whichever judge gateway is configured.
# JUDGE_PROVIDER selects the wire protocol:
#   anthropic           — native Anthropic Messages API (api.anthropic.com).
#                         JUDGE_API_KEY: Anthropic key (sk-ant-...).
#                         JUDGE_MODEL: e.g. "claude-sonnet-4.6".
#   openrouter          — OpenAI-compatible via OpenRouter.
#                         JUDGE_API_KEY: OpenRouter key (sk-or-...).
#                         JUDGE_MODEL: e.g. "anthropic/claude-sonnet-4.6".
#                         JUDGE_BASE_URL: optional (defaults to OpenRouter URL).
#   vercel              — OpenAI-compatible via Vercel AI Gateway.
#                         JUDGE_API_KEY: Vercel API key.
#                         JUDGE_BASE_URL: required (e.g. https://ai-gateway.vercel.sh/v1).
#                         JUDGE_MODEL: e.g. "google/gemini-2.5-pro".
#   openai_compatible   — Generic OpenAI-compatible gateway (Cloudflare,
#                         self-hosted, native OpenAI, etc.).
#                         JUDGE_BASE_URL: required.
# ---------------------------------------------------------------------------
JUDGE_PROVIDER=anthropic
JUDGE_MODEL=claude-sonnet-4.6
JUDGE_SEED=0
JUDGE_BASE_URL=
JUDGE_API_KEY=
